rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. حماية عامة: منع الوصول الافتراضي لكل شيء
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // الدوال المساعدة (Helpers)
    // ===============================================================
    
    function isSignedIn() { return request.auth != null; }
    
    // التحقق مما إذا كان المستخدم مشرفاً (Admin)
    // يتم التحقق عبر البريد الإلكتروني أو الحقل الموجود في مجموعة users
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email in ["samesaeed456@gmail.com", "samisaeed2027@gmail.com", "967776668370@elite-store.local"] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        exists(/databases/$(database)/documents/admin_users/$(request.auth.uid))
      );
    }
    
    // التحقق مما إذا كان المستخدم هو صاحب البيانات
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ===============================================================
    // قواعد المجموعات (Collections Rules)
    // ===============================================================

    // مجموعة المستخدمين (Users)
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // مجموعة المشرفين (Admin Users)
    match /admin_users/{adminId} {
      allow read: if isAdmin() || isOwner(adminId) || (isSignedIn() && resource.data.email == request.auth.token.email);
      allow write: if isAdmin();
      allow list: if isAdmin();
    }

    // المنتجات والأقسام والمدونة (الوصول عام للقراءة، خاص للمشرفين للكتابة)
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /blog_posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // الطلبات (Orders)
    match /orders/{orderId} {
      allow create: if true; // السماح بإنشاء الطلبات (حتى للضيوف)
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // الإعدادات (Settings)
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // سجلات النشاط (Activity Logs)
    match /activity_logs/{logId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // التنبيهات (Notifications)
    match /users/{userId}/notifications/{notificationId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }

    // كوبونات الخصم (Coupons)
    match /coupons/{couponId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // التوصيل والمناطق (Shipping Zones)
    match /shipping_zones/{zoneId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // رسائل الدعم (Support Tickets / Messages)
    match /support_tickets/{ticketId} {
      allow create: if true;
      allow read, update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // اختبار الاتصال (Connection Test)
    match /test/connection {
      allow read: if true;
    }
    
    match /system/connection_test {
      allow read: if true;
    }
  }
}
